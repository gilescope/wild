formatter:
  retain_line_breaks: true
  eof_newline: true

# Stay in `standard` mode (default) so the workflow's `yamlfmt -lint .`
# keeps working — doublestar mode treats `.` as a literal file pattern,
# breaking that invocation with "read .: is a directory". In standard
# mode, exclude entries are directory or file paths (no globbing).

# LLVM `obj2yaml` outputs used as wasm-link test fixtures — these need to
# round-trip byte-exact, so we don't let yamlfmt rewrite them. Directory
# excludes apply recursively to every yaml/yml inside the tree.
exclude:
  - "wild/tests/lld-wasm"
